# Copia este archivo a .env y rellena los valores (nunca subas .env al repositorio).

# Proveedor de base de datos: "memory" (por defecto) o "mongodb"
DB_PROVIDER=memory

# MongoDB (solo si DB_PROVIDER=mongodb)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=laria_db

# Proveedor de IA: "kimi" (por defecto) o "openai"
IA_PROVIDER=kimi

# Kimi / Moonshot API (clave en https://platform.moonshot.cn/)
KIMI_API_KEY=

# OpenAI API (solo si IA_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# JWT (genera una clave larga aleatoria, p. ej. openssl rand -hex 32)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Aplicación
DEBUG=false