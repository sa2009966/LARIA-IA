# Copia este archivo a .env y rellena los valores (nunca subas .env al repositorio).

# Proveedor de base de datos: "memory" (por defecto) o "mongodb"
DB_PROVIDER=memory

# MongoDB (solo si DB_PROVIDER=mongodb)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=laria_db

# Credenciales de MongoDB para docker-compose (obligatorias al usar docker compose)
MONGO_USERNAME=
MONGO_PASSWORD=

# Proveedor de IA (solo openai)
IA_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# JWT — OBLIGATORIA: la app no arranca sin una clave de >= 32 caracteres.
# Genera una con: openssl rand -hex 32
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS: orígenes permitidos del frontend (array JSON)
CORS_ORIGINS=["http://localhost:3000"]

# Admin inicial (opcional): se crea al arrancar si ambos campos están definidos
# Contraseña: mínimo 12 chars, mayúsculas, minúsculas y dígito
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Aplicación
DEBUG=false
# Documentación Swagger/OpenAPI (desactivar en producción pública)
ENABLE_DOCS=true
# Rate limiting (desactivar solo en tests)
RATE_LIMIT_ENABLED=true
