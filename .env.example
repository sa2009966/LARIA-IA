# Copia este archivo a .env y rellena los valores (nunca subas .env al repositorio).

# Base de datos MySQL (usuario, contraseña y nombre de BD reales en tu máquina)
DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost:3306/laria_db

# Kimi / Moonshot API (clave en https://platform.moonshot.cn/ o tu panel)
KIMI_API_KEY=

# JWT (genera una clave larga aleatoria, p. ej. openssl rand -hex 32)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Aplicación
DEBUG=false
